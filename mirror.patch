+bool ICE_data::sendRetry(juice_agent_t *agent,const char *data, int len) {
+        switch(juice_send(agent, data,len)) {
+            case JUICE_ERR_SUCCESS: return true;
+            case JUICE_ERR_FAILED: 
+                    break;
+            case JUICE_ERR_AGAIN:
+                    usleep(1000);
