+            LOGGERICE("%s %d: ICE::Connect::connect no agent\n",pass->getICEname().data(),pass->side);
+            return newConnection(index);
+            }
+        else {
+               std::lock_guard<std::mutex> lck(receiveThreadMutex);
+               wakeReceiver=true;
+               receiveThreadCon.notify_one();
+              }
+        return -2;
+        }
