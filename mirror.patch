+  const char *id = env->GetStringUTFChars(jid, NULL);
+  if (id == nullptr)
+    return false;
+  destruct dest([jid, id, env]() { env->ReleaseStringUTFChars(jid, id); });
+  uint8_t *nid = settings->data()->watchid;
+  for (int i = 0; i < 16; i++) {
+    char h = id[i * 2];
+    if (!isxdigit(h))
+      return false;
+    char l = id[i * 2 + 1];
