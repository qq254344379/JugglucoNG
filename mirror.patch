+    };
+virtual  int  getSenderIdent() const override {
+    return getIdent(); 
+    };
+
+
+ virtual  bool  isConnectedReceiver() const override {
+        if(icedata[1].shutdown) {
+                return false;
+                }
+        if(!agent.load())
