<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/aod_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp"
    android:gravity="center_horizontal">

    <!-- Text Container with Generous Padding -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="40dp">

        <!-- Header: Centered -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/notification_glucose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:contentDescription="Glucose Value" />

            <ImageView
                android:id="@+id/notification_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/novalue"
                android:contentDescription="Trend" />
        </LinearLayout>

        <!-- Status Text -->
        <TextView
            android:id="@+id/notification_status"
            style="@style/TextAppearance.Compat.Notification.Info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:alpha="0.8"
            android:layout_marginBottom="8dp"/>
    </LinearLayout>

    <!-- Content: Chart (Edge-to-Edge) -->
    <ImageView
        android:id="@+id/notification_chart"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:src="@android:color/transparent"
        android:contentDescription="Glucose History Chart" />

</LinearLayout>
